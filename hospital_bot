from config import MAX_PATIENTS_PER_SLOT
from services.db import Appointment

DOCTOR_SCHEDULE = {
    "Dr. Sharma": {
        "days": ["monday", "wednesday", "friday"],
        "slots": ["10:00", "10:30", "11:00"]
    },
    "Dr. Khan": {
        "days": ["tuesday", "thursday"],
        "slots": ["15:00", "15:30", "16:00"]
    }
}

def get_available_slots(db, doctor, date):
    slots = DOCTOR_SCHEDULE[doctor]["slots"]
    available = []

    for slot in slots:
        count = db.query(Appointment).filter_by(
            doctor=doctor,
            date=date,
            time=slot
        ).count()

        if count < MAX_PATIENTS_PER_SLOT:
            available.append(slot)

    return available
